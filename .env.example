# ──────────────────────────────────────────────────────────────────────────────
# CareClaimAI — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=careclaim

# ── Redis (for real-time pub/sub alerts) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI API (for AutoGen multi-agent reasoning) ────────────────────────────
# Get from: https://platform.openai.com/api-keys
# OPTIONAL: falls back to rule-based reasoning if not set
OPENAI_API_KEY=sk-...

# ── HuggingFace (for model downloads) ─────────────────────────────────────────
# Optional: increases rate limits for model downloads
HF_TOKEN=hf_...

# ── API Configuration ─────────────────────────────────────────────────────────
API_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000

# ── Scraper Settings ──────────────────────────────────────────────────────────
SCRAPER_CONCURRENCY=5
SCRAPER_TIMEOUT=30
SCAN_INTERVAL_MINUTES=30

# ── NLP Settings ──────────────────────────────────────────────────────────────
USE_GPU=false
NER_CONFIDENCE_THRESHOLD=0.70

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/careclaim_ai.log
